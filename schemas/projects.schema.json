{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthrise-developers-academy-lab.github.io/developers-academy-github-guide/schemas/projects.schema.json",
  "title": "Synthetic Developers Academy project registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "last_updated", "projects"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "last_updated": {"type": "string", "format": "date"},
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/project"}
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id", "title", "summary", "start_year", "end_year",
        "cohorts", "topics", "project_type", "status", "handoff_status",
        "synthetic", "last_updated", "keywords"
      ],
      "properties": {
        "project_id": {"type": "string", "pattern": "^DA-EO-[0-9]{3}$"},
        "title": {"type": "string", "minLength": 1},
        "short_title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "start_year": {"type": "integer", "minimum": 1900, "maximum": 2100},
        "end_year": {"type": ["integer", "null"], "minimum": 1900, "maximum": 2100},
        "cohorts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "topics": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["water-resources", "climate-resilience", "agriculture", "disasters", "air-quality", "ecology", "urban-environment", "public-health", "data-infrastructure", "education-outreach"]}
        },
        "project_type": {"enum": ["analysis", "research", "prototype", "decision-support", "data-product", "web-application", "training"]},
        "status": {"enum": ["active", "completed", "continued", "archived"]},
        "handoff_status": {"enum": ["not-started", "draft", "accepted", "archived", "not-applicable"]},
        "synthetic": {"const": true},
        "last_updated": {"type": "string", "format": "date"},
        "repository_url": {"type": "string", "minLength": 1},
        "application_url": {"type": "string", "minLength": 1},
        "developedia_url": {"type": "string", "minLength": 1},
        "handoff_url": {"type": "string", "minLength": 1},
        "keywords": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}
      }
    }
  }
}
