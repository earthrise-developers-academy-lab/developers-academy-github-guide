{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthrise-developers-academy-lab.github.io/developers-academy-github-guide/schemas/project-service-areas.schema.json",
  "title": "Synthetic project service areas",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "schema_version", "last_updated", "features"],
  "properties": {
    "type": {"const": "FeatureCollection"},
    "schema_version": {"const": "1.0.0"},
    "last_updated": {"type": "string", "format": "date"},
    "features": {"type": "array", "items": {"$ref": "#/$defs/feature"}}
  },
  "$defs": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "properties", "geometry"],
      "properties": {
        "type": {"const": "Feature"},
        "id": {"type": "string", "minLength": 1},
        "properties": {"$ref": "#/$defs/properties"},
        "geometry": {"$ref": "#/$defs/geometry"}
      }
    },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_area_id", "project_id", "label", "geography_type", "geometry_representation", "geometry_precision", "geometry_source", "source_license", "synthetic"],
      "properties": {
        "service_area_id": {"type": "string", "pattern": "^DA-EO-[0-9]{3}-SA-[0-9]{2}$"},
        "project_id": {"type": "string", "pattern": "^DA-EO-[0-9]{3}$"},
        "label": {"type": "string", "minLength": 1},
        "geography_type": {"enum": ["site", "municipality", "county", "state-province", "watershed", "multi-jurisdiction-region", "country", "national", "other"]},
        "geometry_representation": {"enum": ["exact-project-boundary", "administrative-region", "broad-service-region", "representative-location", "generalized-location"]},
        "geometry_precision": {"enum": ["exact", "approximate", "generalized", "representative"]},
        "geometry_source": {"type": "string", "minLength": 1},
        "source_license": {"type": "string", "minLength": 1},
        "synthetic": {"const": true},
        "geometry_source_url": {"type": "string", "minLength": 1},
        "source_version": {"type": "string", "minLength": 1},
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "geometry": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["type", "coordinates"], "properties": {"type": {"const": "Point"}, "coordinates": {"$ref": "#/$defs/position"}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "coordinates"], "properties": {"type": {"const": "MultiPoint"}, "coordinates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/position"}}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "coordinates"], "properties": {"type": {"const": "Polygon"}, "coordinates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ring"}}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "coordinates"], "properties": {"type": {"const": "MultiPolygon"}, "coordinates": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ring"}}}}}
      ]
    },
    "position": {"type": "array", "minItems": 2, "maxItems": 2, "prefixItems": [{"type": "number", "minimum": -180, "maximum": 180}, {"type": "number", "minimum": -90, "maximum": 90}]},
    "ring": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/position"}}
  }
}
